{
  "name": "bestie-app-template",
  "version": "1.0.0",
  "description": "Bestie AI Relationship Coach Web Application",
  "main": "index.html",
  "scripts": {
    "dev": "npm run build-css && npm run serve",
    "start:full": "node server.js",
    "build": "npm run build-css-prod && npm run minify",
    "build-css": "npx @tailwindcss/cli -i ./assets/css/src/main.css -o ./assets/css/style.css --watch",
    "build-css-prod": "npx @tailwindcss/cli -i ./assets/css/src/main.css -o ./assets/css/style.css --minify",
    "serve": "python -m http.server 8000",
    "serve:api": "node server.js",
    "minify": "html-minifier --input-dir . --output-dir ./dist --file-ext html --minify-css --minify-js --remove-comments --collapse-whitespace"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "html-minifier": "^4.0.0",
    "postcss": "^8.4.32"
  },
  "dependencies": {
    "gsap": "^3.12.2"
  }
}
